generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model appointments {
  id                  String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id          String              @db.Uuid
  service_id          String              @db.Uuid
  location_id         String              @db.Uuid
  appointment_date    DateTime            @db.Date
  start_time          DateTime            @db.Time(6)
  end_time            DateTime            @db.Time(6)
  status              appointment_status? @default(pending)
  notes               String?
  cancellation_reason String?
  reminder_sent       Boolean?            @default(false)
  created_at          DateTime?           @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?           @default(now()) @db.Timestamptz(6)
  doctor_id           String              @db.Uuid
  doctors             doctors             @relation(fields: [doctor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  locations           locations           @relation(fields: [location_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users               users               @relation(fields: [patient_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  services            services            @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  invoices            invoices[]
  medical_records     medical_records[]
  notification_logs   notification_logs[]
  payments            payments[]

  @@index([appointment_date], map: "idx_appointments_date")
  @@index([doctor_id], map: "idx_appointments_doctor_id")
  @@index([patient_id], map: "idx_appointments_patient_id")
  @@index([status], map: "idx_appointments_status")
}

model articles {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  author_id      String?   @db.Uuid
  title          String    @db.VarChar(255)
  slug           String    @unique @db.VarChar(255)
  excerpt        String?
  content        String
  featured_image String?
  category       String?   @db.VarChar(100)
  tags           String[]
  is_published   Boolean?  @default(false)
  published_at   DateTime? @db.Timestamptz(6)
  views          Int?      @default(0)
  created_at     DateTime? @default(now()) @db.Timestamptz(6)
  updated_at     DateTime? @default(now()) @db.Timestamptz(6)
  users          users?    @relation(fields: [author_id], references: [id], onUpdate: NoAction)

  @@index([is_published, published_at], map: "idx_articles_published")
  @@index([slug], map: "idx_articles_slug")
}

model doctor_services {
  doctor_id  String   @db.Uuid
  service_id String   @db.Uuid
  doctors    doctors  @relation(fields: [doctor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  services   services @relation(fields: [service_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@id([doctor_id, service_id])
}

model doctors {
  id                  String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id             String?                @unique @db.Uuid
  location_id         String?                @db.Uuid
  specialization      doctor_specialization?
  license_number      String?                @db.VarChar(100)
  bio                 String?
  years_of_experience Int?
  consultation_fee    Decimal?               @db.Decimal(10, 2)
  is_available        Boolean?               @default(true)
  created_at          DateTime?              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime?              @default(now()) @db.Timestamptz(6)
  appointments        appointments[]
  doctor_services     doctor_services[]
  locations           locations?             @relation(fields: [location_id], references: [id], onUpdate: NoAction)
  users               users?                 @relation(fields: [user_id], references: [id], onUpdate: NoAction)
  medical_records     medical_records[]
  schedule_exceptions schedule_exceptions[]
  time_slots          time_slots[]
}

model locations {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String         @db.VarChar(255)
  address      String
  city         String         @db.VarChar(100)
  state        String?        @db.VarChar(100)
  postal_code  String?        @db.VarChar(20)
  country      String?        @default("Philippines") @db.VarChar(100)
  phone        String?        @db.VarChar(50)
  email        String?        @db.VarChar(255)
  opening_time DateTime?      @default(dbgenerated("'08:00:00'::time without time zone")) @db.Time(6)
  closing_time DateTime?      @default(dbgenerated("'17:00:00'::time without time zone")) @db.Time(6)
  is_active    Boolean?       @default(true)
  image_url    String?
  google_maps_url String?
  latitude     Decimal?       @db.Decimal(10, 8)
  longitude    Decimal?       @db.Decimal(11, 8)
  created_at   DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at   DateTime?      @default(now()) @db.Timestamptz(6)
  appointments appointments[]
  doctors      doctors[]
  time_slots   time_slots[]
}

model medical_records {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id     String        @db.Uuid
  appointment_id String?       @db.Uuid
  diagnosis      String?
  treatment      String?
  prescription   String?
  notes          String?
  attachments    Json?
  follow_up_date DateTime?     @db.Date
  created_at     DateTime?     @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?     @default(now()) @db.Timestamptz(6)
  doctor_id      String?       @db.Uuid
  appointments   appointments? @relation(fields: [appointment_id], references: [id], onUpdate: NoAction)
  doctors        doctors?      @relation(fields: [doctor_id], references: [id], onUpdate: NoAction)
  users          users         @relation(fields: [patient_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model notification_logs {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id           String?       @db.Uuid
  appointment_id    String?       @db.Uuid
  notification_type String        @db.VarChar(50)
  channel           String?       @default("email") @db.VarChar(20)
  recipient         String        @db.VarChar(255)
  subject           String?       @db.VarChar(255)
  content           String?
  status            String?       @default("pending") @db.VarChar(20)
  sent_at           DateTime?     @db.Timestamptz(6)
  error_message     String?
  created_at        DateTime?     @default(now()) @db.Timestamptz(6)
  appointments      appointments? @relation(fields: [appointment_id], references: [id], onUpdate: NoAction)
  users             users?        @relation(fields: [user_id], references: [id], onUpdate: NoAction)
}

model password_reset_tokens {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token      String    @unique @db.VarChar(255)
  expires_at DateTime  @db.Timestamptz(6)
  used_at    DateTime? @db.Timestamptz(6)
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model payments {
  id                       String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointment_id           String?         @db.Uuid
  patient_id               String          @db.Uuid
  amount                   Decimal         @db.Decimal(10, 2)
  currency                 String?         @default("PHP") @db.VarChar(3)
  status                   payment_status? @default(pending)
  payment_method           String?         @db.VarChar(50)
  stripe_payment_intent_id String?         @db.VarChar(255)
  stripe_charge_id         String?         @db.VarChar(255)
  paid_at                  DateTime?       @db.Timestamptz(6)
  refunded_at              DateTime?       @db.Timestamptz(6)
  created_at               DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at               DateTime?       @default(now()) @db.Timestamptz(6)
  appointments             appointments?   @relation(fields: [appointment_id], references: [id], onUpdate: NoAction)
  users                    users           @relation(fields: [patient_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([patient_id], map: "idx_payments_patient_id")
  @@index([stripe_payment_intent_id], map: "idx_payments_stripe_intent")
}

model promotions {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title               String    @db.VarChar(255)
  description         String?
  discount_percentage Decimal?  @db.Decimal(5, 2)
  discount_amount     Decimal?  @db.Decimal(10, 2)
  promo_code          String?   @unique @db.VarChar(50)
  image_url           String?
  service_id          String?   @db.Uuid
  start_date          DateTime  @db.Date
  end_date            DateTime  @db.Date
  is_active           Boolean?  @default(true)
  max_uses            Int?
  current_uses        Int?      @default(0)
  created_at          DateTime? @default(now()) @db.Timestamptz(6)
  updated_at          DateTime? @default(now()) @db.Timestamptz(6)
  services            services? @relation(fields: [service_id], references: [id], onUpdate: NoAction)

  @@index([is_active, start_date, end_date], map: "idx_promotions_active")
}

model services {
  id               String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String            @db.VarChar(255)
  description      String?
  category         service_category? @default(General)
  duration_minutes Int?              @default(30)
  price            Decimal           @db.Decimal(10, 2)
  image_url        String?
  is_active        Boolean?          @default(true)
  created_at       DateTime?         @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?         @default(now()) @db.Timestamptz(6)
  appointments     appointments[]
  doctor_services  doctor_services[]
  promotions       promotions[]
}

model sessions {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String    @db.Uuid
  token      String    @unique @db.VarChar(255)
  expires_at DateTime  @db.Timestamptz(6)
  ip_address String?   @db.VarChar(45)
  user_agent String?
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  users      users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([token], map: "idx_sessions_token")
  @@index([user_id], map: "idx_sessions_user_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model time_slots {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  location_id  String?    @db.Uuid
  day_of_week  Int?
  start_time   DateTime   @db.Time(6)
  end_time     DateTime   @db.Time(6)
  is_available Boolean?   @default(true)
  created_at   DateTime?  @default(now()) @db.Timestamptz(6)
  doctor_id    String?    @db.Uuid
  doctors      doctors?   @relation(fields: [doctor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  locations    locations? @relation(fields: [location_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model users {
  id                      String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                   String                  @unique @db.VarChar(255)
  password_hash           String                  @db.VarChar(255)
  first_name              String                  @db.VarChar(100)
  last_name               String                  @db.VarChar(100)
  phone                   String?                 @db.VarChar(50)
  role                    user_role?              @default(patient)
  avatar_url              String?
  date_of_birth           DateTime?               @db.Date
  address                 String?
  emergency_contact_name  String?                 @db.VarChar(255)
  emergency_contact_phone String?                 @db.VarChar(50)
  is_active               Boolean?                @default(true)
  email_verified          Boolean?                @default(false)
  email_verified_at       DateTime?               @db.Timestamptz(6)
  last_login_at           DateTime?               @db.Timestamptz(6)
  created_at              DateTime?               @default(now()) @db.Timestamptz(6)
  updated_at              DateTime?               @default(now()) @db.Timestamptz(6)
  city                    String?                 @db.VarChar(100)
  gender                  gender?
  postal_code             String?                 @db.VarChar(20)
  state                   String?                 @db.VarChar(100)
  street                  String?                 @db.VarChar(255)
  is_guest                Boolean?                @default(false)
  appointments            appointments[]
  articles                articles[]
  audit_logs              audit_logs[]
  doctors                 doctors?
  insurance_details       insurance_details[]
  invoices                invoices[]
  medical_records         medical_records[]
  notification_logs       notification_logs[]
  password_reset_tokens   password_reset_tokens[]
  patient_consents        patient_consents[]
  payments                payments[]
  sessions                sessions[]
  user_roles              user_roles[]
  vitals                  vitals[]

  @@index([email], map: "idx_users_email")
  @@index([role], map: "idx_users_role")
}

model patient_consents {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id    String       @db.Uuid
  consent_type  consent_type
  content       String?
  signature_url String?
  signed_at     DateTime     @default(now()) @db.Timestamptz(6)
  patient       users        @relation(fields: [patient_id], references: [id], onDelete: Cascade)
}

model invoices {
  id             String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  appointment_id String?        @db.Uuid
  patient_id     String         @db.Uuid
  status         invoice_status @default(UNPAID)
  due_date       DateTime?      @db.Timestamptz(6)
  created_at     DateTime?      @default(now()) @db.Timestamptz(6)
  updated_at     DateTime?      @default(now()) @db.Timestamptz(6)
  amount         Decimal        @db.Decimal(10, 2)
  invoice_number String         @unique @db.VarChar(50)
  tax            Decimal        @default(0) @db.Decimal(10, 2)
  total          Decimal        @db.Decimal(10, 2)
  appointment    appointments?  @relation(fields: [appointment_id], references: [id])
  patient        users          @relation(fields: [patient_id], references: [id], onDelete: Cascade)
}

model insurance_details {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id    String    @db.Uuid
  provider_name String    @db.VarChar(255)
  policy_number String    @db.VarChar(100)
  group_number  String?   @db.VarChar(100)
  expiry_date   DateTime? @db.Date
  is_active     Boolean?  @default(true)
  patient       users     @relation(fields: [patient_id], references: [id], onDelete: Cascade)
}

model audit_logs {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String?  @db.Uuid
  old_values Json?
  new_values Json?
  ip_address String?  @db.VarChar(45)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  record_id  String   @db.Uuid
  table_name String   @db.VarChar(100)
  action     String   @db.VarChar(50)
  user       users?   @relation(fields: [user_id], references: [id])
}

model expenses {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  description String    @db.VarChar(255)
  amount      Decimal   @db.Decimal(10, 2)
  category    String?   @db.VarChar(100)
  date        DateTime  @db.Date
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
}

model roles {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String             @unique @db.VarChar(50)
  description      String?
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?          @default(now()) @db.Timestamptz(6)
  role_permissions role_permissions[]
  user_roles       user_roles[]

  @@index([name], map: "idx_roles_name")
}

model permissions {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String             @unique @db.VarChar(100)
  description      String?
  created_at       DateTime?          @default(now()) @db.Timestamptz(6)
  updated_at       DateTime?          @default(now()) @db.Timestamptz(6)
  role_permissions role_permissions[]

  @@index([name], map: "idx_permissions_name")
}

model role_permissions {
  role_id       String      @db.Uuid
  permission_id String      @db.Uuid
  created_at    DateTime?   @default(now()) @db.Timestamptz(6)
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@index([role_id], map: "idx_role_permissions_role_id")
  @@index([permission_id], map: "idx_role_permissions_perm_id")
}

model user_roles {
  user_id     String    @db.Uuid
  role_id     String    @db.Uuid
  assigned_at DateTime? @default(now()) @db.Timestamptz(6)
  roles       roles     @relation(fields: [role_id], references: [id], onDelete: Cascade)
  users       users     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([user_id, role_id])
  @@index([user_id], map: "idx_user_roles_user_id")
  @@index([role_id], map: "idx_user_roles_role_id")
}

model vitals {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  patient_id           String    @db.Uuid
  blood_glucose_before String?   @db.VarChar(50)
  blood_glucose_after  String?   @db.VarChar(50)
  temperature          String?   @db.VarChar(50)
  blood_pressure       String?   @db.VarChar(50)
  height               String?   @db.VarChar(50)
  weight               String?   @db.VarChar(50)
  created_at           DateTime? @default(now()) @db.Timestamptz(6)
  updated_at           DateTime? @default(now()) @db.Timestamptz(6)
  users                users     @relation(fields: [patient_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model schedule_exceptions {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  doctor_id   String    @db.Uuid
  date        DateTime  @db.Date
  start_time  DateTime? @db.Time(6)
  end_time    DateTime? @db.Time(6)
  is_full_day Boolean   @default(true)
  reason      String?   @db.VarChar(255)
  created_at  DateTime? @default(now()) @db.Timestamptz(6)
  doctors     doctors   @relation(fields: [doctor_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([doctor_id, date], map: "idx_schedule_exceptions_doc_date")
}

enum appointment_status {
  pending
  confirmed
  completed
  cancelled
  no_show
}

enum payment_status {
  pending
  paid
  refunded
  failed
}

enum user_role {
  admin
  staff
  patient
  doctor
  nurse
}

enum doctor_specialization {
  OB_GYN
  IM
  Pedia
  Gastro
  Liver
  Infectious
  Nephro
  Rheuma
  Surgery
  ENT
  Rehab
  Derma
  Ultrasound
}

enum gender {
  MALE
  FEMALE
  OTHER
}

enum consent_type {
  GENERAL
  TREATMENT
  SURGERY
  DATA_SHARING
}

enum invoice_status {
  UNPAID
  PAID
  VOID
  PARTIAL
}

enum service_category {
  General
  Specialist
  Diagnostic
  Emergency
  Wellness
  Surgery
}
